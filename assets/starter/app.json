{
  "schemaVersion": 1,
  "appId": "starter-app",
  "name": "Starter Notes",
  "nameI18n": {
    "zh-CN": "Starter Notes",
    "en-US": "Starter Notes"
  },
  "version": "1.0.0",
  "description": "An offline-first bilingual CEAPP starter with one useful local feature.",
  "descriptionI18n": {
    "zh-CN": "一个离线优先、双语并包含实用本地功能的 CEAPP 起点。",
    "en-US": "An offline-first bilingual CEAPP starter with one useful local feature."
  },
  "entry": "index.html",
  "icon": "assets/logo.png",
  "minCanEngineVersion": "1.5.8",
  "platforms": [
    {
      "os": "*",
      "arch": "*"
    }
  ],
  "commands": {
    "noop": {
      "executable": "echo",
      "baseArgs": [
        "starter-app"
      ],
      "allowedFlags": []
    }
  },
  "capabilities": {
    "dataBridge": {
      "required": false,
      "local": {
        "enabled": true,
        "dbFile": "starter-app.sqlite",
        "schemaEntry": "data/localdb.schema.json",
        "schemaVersion": 1
      }
    }
  },
  "permissions": [
    "data.read",
    "data.write"
  ]
}
